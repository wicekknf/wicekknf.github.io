<!DOCTYPE html>
<html lang="pl">
	<head>
		<meta charset="UTF-8" />
		<meta
			name="viewport"
			content="width=device-width, initial-scale=1.0"
		/>
		<link
			rel="stylesheet"
			href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css"
		/>
		<link
			rel="preconnect"
			href="https://fonts.googleapis.com"
		/>
		<link
			rel="preconnect"
			href="https://fonts.gstatic.com"
			crossorigin
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Raleway:ital,wght@0,100..900;1,100..900&display=swap"
			rel="stylesheet"
		/>
		<title>Forest Group/oferta</title>
		<link
			rel="stylesheet"
			href="./dist/css/style.min.css"
		/>
	</head>
	<body>
		<nav>
			<div class="logo-nav"><i class="ti ti-christmas-tree"></i> Forest</div>
			<div class="nav-list">
				<a
					class="a-style"
					href="index.html"
					>Home</a
				>
				<a
					class="a-style"
					href="index.html"
					>O nas</a
				>
				<a
					class="a-style"
					href="#offer"
					>Oferta</a
				>
				<a
					class="a-style"
					href="contact.html"
					>Kontakt</a
				>
			</div>

			<div class="mini-nav">
				<div class="icon-box">
					<div class="hamburger-icon"><i class="ti ti-menu-2"></i></div>
					<div class="close-icon"><i class="ti ti-x"></i></div>
				</div>
				<div class="mini-nav-list">
					<a href="index.html">Home</a>
					<a href="index.html">O nas</a>
					<a href="#offer">Oferta</a>
					<a href="contact.html">Kontakt</a>
				</div>
			</div>
		</nav>

		<div class="hero">
			<div class="hero-shadow"></div>
			<div class="hero-text">
				<p>Forest Group</p>
				<h1>Najpiękniejszy park w Twojej okolicy!</h1>
			</div>
		</div>

		<section
			id="offer"
			class="wrapper offer"
		>
			<h2 class="section-title">oferta</h2>

			<p>Wybierz jedną z naszych wspaniałych ofert!</p>

			<div class="cards offer-page">
				<div class="card one">
					<h3>Demo</h3>
					<p class="price">$0</p>
					<ul class="card-list">
						<li><i class="ti ti-check"></i> opcja w pakiecie</li>
						<li><i class="ti ti-check"></i> opcja w pakiecie</li>
						<li><i class="ti ti-minus"></i> opcja poza pakietem</li>
						<li><i class="ti ti-minus"></i> opcja poza pakietem</li>
						<li><i class="ti ti-minus"></i> opcja poza pakietem</li>
					</ul>
					<button class="chose">Wybierz</button>
				</div>

				<div class="card two">
					<h3>Standard</h3>
					<p class="price">$99</p>
					<ul class="card-list">
						<li><i class="ti ti-check"></i> opcja w pakiecie</li>
						<li><i class="ti ti-check"></i> opcja w pakiecie</li>
						<li><i class="ti ti-check"></i> opcja w pakiecie</li>
						<li><i class="ti ti-minus"></i> opcja poza pakietem</li>
						<li><i class="ti ti-minus"></i> opcja poza pakietem</li>
					</ul>
					<button class="chose standard-btn">Wybierz</button>
				</div>

				<div class="card three">
					<h3>Premium</h3>
					<p class="price">$299</p>
					<ul class="card-list">
						<li><i class="ti ti-check"></i> opcja w pakiecie</li>
						<li><i class="ti ti-check"></i> opcja w pakiecie</li>
						<li><i class="ti ti-check"></i> opcja w pakiecie</li>
						<li><i class="ti ti-check"></i> opcja w pakiecie</li>
						<li><i class="ti ti-check"></i> opcja w pakiecie</li>
					</ul>
					<button class="chose">Wybierz</button>
				</div>
				<div class="card one">
					<h3>Demo</h3>
					<p class="price">$0</p>
					<ul class="card-list">
						<li><i class="ti ti-check"></i> opcja w pakiecie</li>
						<li><i class="ti ti-check"></i> opcja w pakiecie</li>
						<li><i class="ti ti-minus"></i> opcja poza pakietem</li>
						<li><i class="ti ti-minus"></i> opcja poza pakietem</li>
						<li><i class="ti ti-minus"></i> opcja poza pakietem</li>
					</ul>
					<button class="chose">Wybierz</button>
				</div>
				<div class="card one">
					<h3>Demo</h3>
					<p class="price">$0</p>
					<ul class="card-list">
						<li><i class="ti ti-check"></i> opcja w pakiecie</li>
						<li><i class="ti ti-check"></i> opcja w pakiecie</li>
						<li><i class="ti ti-minus"></i> opcja poza pakietem</li>
						<li><i class="ti ti-minus"></i> opcja poza pakietem</li>
						<li><i class="ti ti-minus"></i> opcja poza pakietem</li>
					</ul>
					<button class="chose">Wybierz</button>
				</div>
				<div class="card one">
					<h3>Demo</h3>
					<p class="price">$0</p>
					<ul class="card-list">
						<li><i class="ti ti-check"></i> opcja w pakiecie</li>
						<li><i class="ti ti-check"></i> opcja w pakiecie</li>
						<li><i class="ti ti-minus"></i> opcja poza pakietem</li>
						<li><i class="ti ti-minus"></i> opcja poza pakietem</li>
						<li><i class="ti ti-minus"></i> opcja poza pakietem</li>
					</ul>
					<button class="chose">Wybierz</button>
				</div>
			</div>
		</section>

		<!-- @include 'footer.kit' -->

		<script src="./dist/js/main.min.js"></script>
	</body>
</html>
